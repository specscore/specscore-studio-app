rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users: authenticated users can read their own record and create it
    // exactly once (on first sign-in). Updates are not permitted from the
    // client — any mutation to an existing user record must go through the
    // server, which uses the Admin SDK and bypasses these rules.
    //
    // This intentionally leaves a window where the client cannot save
    // per-user state (e.g., a `projects` map) directly. When that surface
    // lands, either (a) add a tightly scoped `update` rule for the specific
    // fields, or (b) move that state into a subcollection with its own rule
    // block — depending on whichever is closer to the actual write pattern.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
    }
  }
}
